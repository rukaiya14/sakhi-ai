# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Local MySQL/PostgreSQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=shebalance

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AWS Configuration (for production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# AWS DynamoDB (optional - for production)
DYNAMODB_TABLE_PREFIX=shebalance-

# AWS S3 (for file uploads in production)
S3_BUCKET_NAME=shebalance-uploads

# AWS SageMaker (for SkillScan)
SAGEMAKER_ENDPOINT_NAME=shebalance-skillscan-endpoint

# AWS Lambda (for AI Sakhi)
AI_SAKHI_LAMBDA_ARN=arn:aws:lambda:us-east-1:123456789:function:ai-sakhi

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password

# WhatsApp API (optional)
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER=+1234567890

# Payment Gateway (optional)
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
