{
  "name": "shebalance-backend",
  "version": "1.0.0",
  "description": "SHE-BALANCE Backend API Server with AWS DynamoDB",
  "main": "server-dynamodb.js",
  "scripts": {
    "start": "node server-dynamodb.js",
    "dev": "nodemon server-dynamodb.js",
    "setup-dynamodb": "node aws-dynamodb-setup.js create",
    "cleanup-dynamodb": "node aws-dynamodb-setup.js delete",
    "init-sample-data": "node scripts/init-dynamodb-data.js"
