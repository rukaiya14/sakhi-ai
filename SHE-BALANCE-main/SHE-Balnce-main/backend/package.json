    "@aws-sdk/client-dynamodb": "^3.1004.0",
    "@aws-sdk/client-polly": "^3.1002.0",
    "@aws-sdk/client-s3": "^3.1002.0",
    "@aws-sdk/client-sts": "^3.1001.0",
    "@aws-sdk/client-transcribe": "^3.1002.0",
    "@aws-sdk/client-translate": "^3.1002.0",
    "@aws-sdk/lib-dynamodb": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1002.0",
    "aws-sdk": "^2.1498.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "twilio": "^5.12.2",
