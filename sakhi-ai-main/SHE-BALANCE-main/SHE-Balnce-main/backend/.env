# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Local MySQL/PostgreSQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=shebalance

# JWT Secret
JWT_SECRET=shebalance-secret-key-2026-change-in-production

# AWS Configuration (for production)
AWS_REGION=us-east-1

# AWS credentials are retrieved from:
# 1. AWS Secrets Manager (secret: shebalance-deployment) - for application credentials
# 2. AWS CLI configuration (~/.aws/credentials) - for accessing Secrets Manager

# AWS DynamoDB (optional - for production)
DYNAMODB_TABLE_PREFIX=shebalance-

# AWS S3 (for file uploads in production)
S3_BUCKET_NAME=shebalance-uploads

# AWS SageMaker (for SkillScan)
SAGEMAKER_ENDPOINT_NAME=shebalance-skillscan-endpoint

# AWS Lambda (for AI Sakhi)
AI_SAKHI_LAMBDA_ARN=

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# WhatsApp API (optional)
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER=

# Payment Gateway (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Twilio WhatsApp Configuration
TWILIO_ACCOUNT_SID=AC4984057b32dd7cf7dd998b07322798b9
TWILIO_AUTH_TOKEN=978bdd914ae43484ec71c66dcf099024
TWILIO_WHATSAPP_NUMBER=+14155238886
